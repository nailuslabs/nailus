{
  "name": "nailuscss",
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "description": "moteur atomique de generation css, des composants, fonts, icons instantaner a la demande",
  "keywords": [
    "nailus",
    "nailuscss",
    "taiwindcss",
    "unocss",
    "windicss",
    "pandacss"
  ],
  "homepage": "https://github.com/nailuslabs/nailus#readme",
  "bugs": {
    "url": "https://github.com/nailuslabs/nailus/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nailuslabs/nailus.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "license": "MIT",
  "author": "nsounda nsilulu naïloth esdras",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nailuscss": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "rollup -cw",
    "tsd": "tsc -p ./src --emitDeclarationOnly",
    "lint": "eslint src test example",
    "lint:fix": "eslint src test example --fix",
    "typecheck": "tsc -p ./src --noEmit",
    "build": "rollup -c && npm run tsd",
    "build:prod": "cross-env NODE_ENV=production npm run build",
    "prepack": "npm run build",
    "test": "node --import ./test/register-loader.mjs ./test/run.ts",
    "test:update": "cross-env UPDATE_SNAPSHOT=true node --import ./test/register-loader.mjs ./test/run.ts",
    "test:dts": "tsc -p ./test/dts --noEmit",
    "coverage": "nyc --nycrc-path=.nycrc.json npm test",
    "release": "bumpp --tag --commit --push"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./colors": {
      "types": "./dist/colors.d.ts",
      "import": "./dist/colors.js",
      "require": "./dist/colors.cjs"
    },
    "./defaultConfig": {
      "types": "./dist/defaultConfig.d.ts",
      "import": "./dist/defaultConfig.js",
      "require": "./dist/defaultConfig.cjs"
    },
    "./defaultTheme": {
      "types": "./dist/defaultTheme.d.ts",
      "import": "./dist/defaultTheme.js",
      "require": "./dist/defaultTheme.cjs"
    },
    "./resolveConfig": {
      "types": "./dist/resolveConfig.d.ts",
      "import": "./dist/resolveConfig.js",
      "require": "./dist/resolveConfig.cjs"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.cjs"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.js",
      "require": "./dist/helpers/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./utils/parser": {
      "types": "./dist/utils/parser/index.d.ts",
      "import": "./dist/utils/parser/index.js",
      "require": "./dist/utils/parser/index.cjs"
    },
    "./utils/style": {
      "types": "./dist/utils/style/index.d.ts",
      "import": "./dist/utils/style/index.js",
      "require": "./dist/utils/style/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "require": "./dist/plugin/index.cjs"
    },
    "./plugin/aspect-ratio": {
      "types": "./dist/plugin/aspect-ratio/index.d.ts",
      "import": "./dist/plugin/aspect-ratio/index.js",
      "require": "./dist/plugin/aspect-ratio/index.cjs"
    },
    "./plugin/filters": {
      "types": "./dist/plugin/filters/index.d.ts",
      "import": "./dist/plugin/filters/index.js",
      "require": "./dist/plugin/filters/index.cjs"
    },
    "./plugin/forms": {
      "types": "./dist/plugin/forms/index.d.ts",
      "import": "./dist/plugin/forms/index.js",
      "require": "./dist/plugin/forms/index.cjs"
    },
    "./plugin/line-clamp": {
      "types": "./dist/plugin/line-clamp/index.d.ts",
      "import": "./dist/plugin/line-clamp/index.js",
      "require": "./dist/plugin/line-clamp/index.cjs"
    },
    "./plugin/typography": {
      "types": "./dist/plugin/typography/index.d.ts",
      "import": "./dist/plugin/typography/index.js",
      "require": "./dist/plugin/typography/index.cjs"
    },
    "./plugin/scroll-snap": {
      "types": "./dist/plugin/scroll-snap/index.d.ts",
      "import": "./dist/plugin/scroll-snap/index.js",
      "require": "./dist/plugin/scroll-snap/index.cjs"
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/color-string": "^1.5.5",
    "@types/diff": "^7.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/jasmine": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "arg": "^5.0.2",
    "bumpp": "^11.0.1",
    "caller-path": "^4.0.0",
    "chokidar-cli": "^3.0.0",
    "color-string": "^2.1.4",
    "cross-env": "^10.1.0",
    "diff": "^9.0.0",
    "domhandler": "^6.0.1",
    "eslint": "^10.2.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "jasmine": "^6.2.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "mini-svg-data-uri": "^1.4.4",
    "minimatch": "^10.2.5",
    "nyc": "^18.0.0",
    "picocolors": "^1.1.1",
    "pirates": "^4.0.7",
    "rollup": "^4.60.2",
    "sucrase": "^3.35.1",
    "tosource": "^2.0.0-alpha.3",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
