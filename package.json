{
  "name": "@nailus/monorepo",
  "type": "module",
  "version": "1.0.1",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "description": "Moteur atomique de génération css, fonts et Icons instantané à la demande.",
  "keywords": [
    "nailus",
    "unocss",
    "panda-css",
    "tailwindcss",
    "windicss",
    "twind",
    "atomizer",
    "css",
    "ui",
    "js",
    "ts"
  ],
  "homepage": "https://github.com/nailuslabs/nailus#readme",
  "bugs": {
    "url": "https://github.com/nailuslabs/nailus/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nailuslabs/nailus.git"
  },
  "license": "MIT",
  "author": "Naïloth Esdras NSOUNDA NSILULU",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "build:core": "pnpm --filter @nailus/core build",
    "build:all": "pnpm -r run build",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "fs-extra": "^11.3.6",
    "js-yaml": "^5.2.0",
    "rollup": "^4.62.2",
    "typescript": "^6.0.3"
  }
}
